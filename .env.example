# =============================================================================
# Database
# =============================================================================
# Host/credentials used by the PHP application in newMVC/src/model/pdo.php
DB_HOST=db
DB_NAME=auction_site
DB_USER=root
DB_PASSWORD=root

# Host port exposed by docker-compose.yml on the machine running Docker
DB_PORT=3308

# Optional, useful if you want to keep the connection charset explicit
DB_CHARSET=utf8mb4

# =============================================================================
# Meilisearch
# =============================================================================
# Used by the search controllers and search suggestion endpoint
MEILI_HOST=http://meilisearch:7700
MEILI_KEY=CLE_TEST_SAE_SITE
MEILI_MASTER_KEY=CLE_TEST_SAE_SITE

# =============================================================================
# External APIs
# =============================================================================
# Used by newMVC/src/controllers/CelebrityApiController.php
API_NINJAS_KEY=your_api_ninjas_key

# =============================================================================
# Mailjet / Emailing
# =============================================================================
# Used by newMVC/src/controllers/EmailingController.php
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
MAIL_FROM_EMAIL=admin@example.com
MAIL_FROM_NAME="Admin MaBonneEnchere"

# =============================================================================
# Application
# =============================================================================
APP_TIMEZONE=Europe/Paris
APP_URL=http://localhost